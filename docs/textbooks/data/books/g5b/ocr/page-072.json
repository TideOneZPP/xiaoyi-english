{"page":72,"width":1198,"height":1676,"lines":[{"text":"The Mid-Autumn Festival is in September or October.","confidence":95.6,"x":0.17028,"y":0.1068,"width":0.63856,"height":0.0179},{"text":"People look at the moon at night with their families","confidence":96.2,"x":0.17279,"y":0.13604,"width":0.63356,"height":0.0179},{"text":"They eat moon cakes and fruit.","confidence":95.9,"x":0.17028,"y":0.16527,"width":0.38147,"height":0.0179},{"text":"am","confidence":71.5,"x":0.46244,"y":0.21122,"width":0.03589,"height":0.01611},{"text":"ed","confidence":43.3,"x":0.52755,"y":0.34129,"width":0.04925,"height":0.02029},{"text":"The Double Ninth Festival (Chongyang Festival) is in October","confidence":95.3,"x":0.17028,"y":0.41169,"width":0.73456,"height":0.0179},{"text":"or November. It is a festival for old people. People visit their","confidence":96.6,"x":0.17112,"y":0.44033,"width":0.72955,"height":0.0185},{"text":"parents and grandparents. They also climb mountains and","confidence":96.2,"x":0.17195,"y":0.47017,"width":0.71369,"height":0.0179},{"text":"eat rice cakes at this festival.","confidence":96.5,"x":0.17112,"y":0.4994,"width":0.34891,"height":0.01432},{"text":"Gs","confidence":48.2,"x":0.42321,"y":0.66945,"width":0.11269,"height":0.04057},{"text":"Ce","confidence":44.9,"x":0.37646,"y":0.78103,"width":0.07429,"height":0.01969},{"text":"rice dumplings","confidence":96.7,"x":0.72371,"y":0.88663,"width":0.17613,"height":0.0185},{"text":"a rice cake","confidence":87.1,"x":0.13689,"y":0.88723,"width":0.12771,"height":0.01492},{"text":"jiaozi","confidence":79.1,"x":0.36811,"y":0.88723,"width":0.07012,"height":0.0179},{"text":"moon cakes","confidence":96.5,"x":0.5384,"y":0.88723,"width":0.14274,"height":0.01492}]}