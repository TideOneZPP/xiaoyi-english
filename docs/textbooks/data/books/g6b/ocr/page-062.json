{"page":62,"width":1198,"height":1676,"lines":[{"text":"At home, Liu Tao is reading about Australia.","confidence":96.5,"x":0.18531,"y":0.1074,"width":0.5409,"height":0.0185},{"text":"Australia","confidence":96.7,"x":0.14691,"y":0.18377,"width":0.10851,"height":0.01432},{"text":"You will find many interesting things in Australia.","confidence":96.3,"x":0.1803,"y":0.23389,"width":0.60935,"height":0.0179},{"text":"Do you like animals? You will love our kangaroos","confidence":96.2,"x":0.1828,"y":0.26313,"width":0.60351,"height":0.0185},{"text":"and koalas. Sport-lovers will like Australian football","confidence":95.2,"x":0.18197,"y":0.29236,"width":0.63105,"height":0.0179},{"text":"games because they are very exciting.","confidence":96.3,"x":0.18197,"y":0.3216,"width":0.46411,"height":0.0179},{"text":"You will also like Sydney. It is a beautiful city. Many","confidence":95.5,"x":0.1803,"y":0.36217,"width":0.64107,"height":0.0179},{"text":"people visit it every year.","confidence":96.2,"x":0.18197,"y":0.39141,"width":0.30634,"height":0.0179},{"text":"People in Australia welcome visitors. Come and visit","confidence":96.2,"x":0.1828,"y":0.43138,"width":0.62855,"height":0.0185},{"text":"Australia today!","confidence":96.5,"x":0.18114,"y":0.46122,"width":0.19866,"height":0.0173},{"text":"ZS","confidence":93.5,"x":0.67362,"y":0.85024,"width":0.03255,"height":0.01551},{"text":"SS","confidence":53.2,"x":0.74124,"y":0.86456,"width":0.03589,"height":0.01671},{"text":"Australian football","confidence":96.3,"x":0.18614,"y":0.89976,"width":0.22955,"height":0.01432},{"text":"Sydney","confidence":95.7,"x":0.66861,"y":0.89976,"width":0.08765,"height":0.0185}]}