{"page":46,"width":1198,"height":1676,"lines":[{"text":"There is a red light. The bus stops.","confidence":95.7,"x":0.18447,"y":0.10501,"width":0.44825,"height":0.02506},{"text":"Bobby: Why does the bus stop here?","confidence":96.0,"x":0.18948,"y":0.15155,"width":0.47663,"height":0.02387},{"text":"Bear: Look at the red light. means we must stop.","confidence":95.8,"x":0.20785,"y":0.18079,"width":0.65776,"height":0.02506},{"text":"Bobby: Oh, I see.","confidence":94.2,"x":0.18948,"y":0.21002,"width":0.22204,"height":0.02267},{"text":"The bus goes on, but soon it stops again.","confidence":95.8,"x":0.18447,"y":0.49702,"width":0.51503,"height":0.02506},{"text":"Bobby: There aren't any traffic lights here. Why is","confidence":90.1,"x":0.18948,"y":0.54475,"width":0.64858,"height":0.02446},{"text":"the bus stopping again?","confidence":96.8,"x":0.29299,"y":0.57399,"width":0.29716,"height":0.02506},{"text":"Bear: Look! Some elephants are crossing the road.","confidence":96.0,"x":0.20785,"y":0.60263,"width":0.64691,"height":0.02566},{"text":"We must stop and wait.","confidence":96.4,"x":0.29382,"y":0.63305,"width":0.29967,"height":0.02267},{"text":"SS.","confidence":51.6,"x":0.53589,"y":0.86754,"width":0.01586,"height":0.00835},{"text":"anda","confidence":64.4,"x":0.54925,"y":0.8753,"width":0.15192,"height":0.01671}]}