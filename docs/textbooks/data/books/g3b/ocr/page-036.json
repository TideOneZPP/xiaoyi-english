{"page":36,"width":1305,"height":1826,"lines":[{"text":"A Read and match","confidence":92.7,"x":0.11034,"y":0.10515,"width":0.24521,"height":0.01752},{"text":"Where are Bobby's and his friends' paper planes?","confidence":95.6,"x":0.11111,"y":0.1402,"width":0.57241,"height":0.01698},{"text":"aRty","confidence":44.9,"x":0.57395,"y":0.19003,"width":0.0567,"height":0.0126},{"text":"B Act it out","confidence":95.0,"x":0.11188,"y":0.3954,"width":0.15632,"height":0.01807},{"text":"Act out the story in groups.","confidence":96.7,"x":0.11034,"y":0.431,"width":0.30805,"height":0.01698},{"text":"C Play and say","confidence":95.7,"x":0.11111,"y":0.46878,"width":0.1954,"height":0.02136},{"text":"Make a paper plane and fly it. Then say where it is.","confidence":96.1,"x":0.11264,"y":0.50438,"width":0.58238,"height":0.01752},{"text":"Listen to the sentences from the story and read.","confidence":93.3,"x":0.14406,"y":0.61993,"width":0.54713,"height":0.01752},{"text":"I can't find it.","confidence":90.7,"x":0.14636,"y":0.65115,"width":0.16015,"height":0.01479},{"text":"The planes go very far.","confidence":96.4,"x":0.43908,"y":0.65115,"width":0.27969,"height":0.01807},{"text":"Listen to the rhyme and chant along. Then find more words. be","confidence":92.9,"x":0.14406,"y":0.66977,"width":0.7433,"height":0.04272},{"text":"Class is over. It's time to have fun!","confidence":96.2,"x":0.1433,"y":0.73823,"width":0.40996,"height":0.01479},{"text":"In the playground, we love to run.","confidence":95.9,"x":0.1433,"y":0.7678,"width":0.41762,"height":0.01807},{"text":"It's great fun to run and hide.","confidence":94.7,"x":0.1433,"y":0.79682,"width":0.35939,"height":0.01862},{"text":"We have fun with friends outside.","confidence":96.2,"x":0.14253,"y":0.82585,"width":0.41073,"height":0.01479},{"text":"to.","confidence":44.3,"x":0.14176,"y":0.86637,"width":0.36398,"height":0.03834}]}