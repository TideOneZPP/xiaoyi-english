{"page":78,"width":1197,"height":1676,"lines":[{"text":"e Then, Bobby and Billy draw.","confidence":93.2,"x":0.11028,"y":0.10143,"width":0.41688,"height":0.03103},{"text":"Let me draw some bananas on the trees.","confidence":95.6,"x":0.27235,"y":0.15334,"width":0.51211,"height":0.03401},{"text":"Let me draw a rubbish bin.","confidence":94.4,"x":0.47703,"y":0.42721,"width":0.33584,"height":0.03878},{"text":"You shouldn't litter, Bobby.","confidence":87.2,"x":0.47368,"y":0.47136,"width":0.32665,"height":0.02327},{"text":"The poster is ready. They put it at the school gate","confidence":94.5,"x":0.18546,"y":0.56086,"width":0.64244,"height":0.02506},{"text":"What a nice poster! We should","confidence":94.5,"x":0.32247,"y":0.83652,"width":0.39348,"height":0.04057},{"text":"protect the Earth and keep it clean.","confidence":96.6,"x":0.32331,"y":0.88067,"width":0.44862,"height":0.02327}]}